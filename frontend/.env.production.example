# Used when building for production (e.g. on Vercel).
# Copy these into Vercel → Project → Settings → Environment Variables (Production).
# Replace URLs after you know your Render API hostname and Vercel app hostname.

VITE_API_URL=https://debtwatch-api.onrender.com
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://your-api-identifier
VITE_AUTH0_REDIRECT_URI=https://your-app.vercel.app
