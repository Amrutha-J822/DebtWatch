# NOTE: Vite never loads `.env.example`. Copy lines you need into `.env.local`.

# Required in .env.local (Auth0 → Applications → your Single Page App → Client ID):
# VITE_AUTH0_CLIENT_ID=<your_spa_client_id>

# Optional overrides (defaults live in `.env.development` for local dev):
VITE_AUTH0_DOMAIN=debtwatch-dev.us.auth0.com
# Must match an API Identifier in Auth0 → APIs, and your SPA must be authorized for that API
# (Applications → your SPA → APIs, or APIs → your API → authorize the app).
VITE_AUTH0_AUDIENCE=https://debtwatch-api
#
# --- API + backend ---
# Create an API in Auth0 (Dashboard → APIs); Identifier must match VITE_AUTH0_AUDIENCE. Prefer
# authorizing the SPA for that API (Applications → your SPA → APIs). In backend/.env set e.g.
#   AUTH0_AUDIENCE=https://debtwatch-api,<your_spa_client_id>
# so the API accepts either the API access token or the OIDC ID token if the SPA is not yet authorized
# for the API. Restart backend after changes.
#
# --- Auth0 “Callback URL mismatch” fix ---
# The value of VITE_AUTH0_REDIRECT_URI must appear EXACTLY in Auth0 → Applications → your SPA:
# Allowed Callback URLs, Allowed Logout URLs, Allowed Web Origins (same origin string; port matters).
#
# This repo’s dev default is Vite on port 5173 → use redirect http://localhost:5173
# If your Auth0 app ONLY lists http://localhost:3000 or http://localhost:3000/auth/callback,
# either add http://localhost:5173 to those three Auth0 fields, OR set VITE_AUTH0_REDIRECT_URI to
# match what Auth0 already has and run Vite on that port (e.g. npm run dev -- --port 3000).
#
# “Application Login URI” (e.g. https://myapp.org/login) is NOT the OAuth callback URL — ignore it for this check.
#
# Same URL is used for OAuth redirect_uri AND logout returnTo:
# VITE_AUTH0_REDIRECT_URI=http://localhost:5173
# VITE_AUTH0_REDIRECT_URI=https://your-prod-app.example.com
# VITE_API_URL=http://localhost:3001

