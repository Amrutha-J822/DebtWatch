# Copy what you need into `.env.local` (gitignored). Vite does not read this file automatically.

# Required — Auth0 → Applications → your SPA
# VITE_AUTH0_CLIENT_ID=

VITE_AUTH0_DOMAIN=debtwatch-dev.us.auth0.com
VITE_AUTH0_AUDIENCE=https://debtwatch-api

# Must match Allowed Callback / Logout / Web Origins in Auth0 (local dev: port 5173).
# VITE_AUTH0_REDIRECT_URI=http://localhost:5173

# Backend API base (local: port 3001). Production: your Render (or other) API URL.
# VITE_API_URL=http://localhost:3001
