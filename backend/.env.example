# Copy to .env locally. On Render, set each key in Environment (no file upload).

PORT=3001
# Comma-separated browser origins allowed to call this API (local: Vite on port 5173).
FRONTEND_URL=http://localhost:5173
# Optional: also allow https://*.vercel.app (previews) without listing each URL.
CORS_ALLOW_VERCEL=0

# Google Gemini (required for scan triage + explain)
GEMINI_API_KEY=
# Optional overrides:
# GEMINI_REASONING_MODEL=gemini-3.1-pro-preview
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Auth0 (Token Vault exchange + JWT issuer)
AUTH0_DOMAIN=your-tenant.us.auth0.com
# API Identifier from Auth0 → APIs; optionally add SPA Client ID after comma
AUTH0_AUDIENCE=https://your-api-identifier
# Machine-to-machine or custom app used for Vault token exchange (Dashboard → Applications)
AUTH0_CUSTOM_API_CLIENT_ID=
AUTH0_CUSTOM_API_CLIENT_SECRET=

# Optional: anonymous / dev GitHub (when user has no Vault token)
# GITHUB_TOKEN=
# SCAN_TRY_TOKEN_VAULT_FIRST=false

# Optional — upload scan (/api/scan/upload)
# UPLOAD_MAX_ZIP_MB=50
# UPLOAD_MAX_EXTRACTED_MB=200
# UPLOAD_MAX_FILES=500
# UPLOAD_MAX_FILE_MB=1
# UPLOAD_RATE_LIMIT_MAX=8

# Optional
# SLACK_APP_URL=
# CORS_ORIGINS=
